# Overnight Task Manager — Repo Input List
#
# Format: <github_url>  [branch]  ["run_command"]
#
# - Lines starting with # are comments
# - Empty lines are ignored
# - Branch defaults to repo's default branch if omitted
# - Run command is auto-detected if omitted (pytest, make test, etc.)
# - Wrap run_command in double quotes if it contains spaces
#
# Examples:
# -----------------------------------------------------------------------

# Minimal: just a URL — auto-detect branch and test command
https://github.com/huggingface/transformers

# Specify branch
https://github.com/facebookresearch/detectron2  main

# Specify branch + explicit run command (quoted)
https://github.com/openai/whisper  main  "python3 -m pytest tests/ -x -v"

# ML training benchmark on AMD GPU
https://github.com/pytorch/benchmark  main  "python3 run_benchmark.py --device hip --model resnet50 --batch-size 32"

# LLM inference test
https://github.com/vllm-project/vllm  main  "python3 benchmarks/benchmark_throughput.py --model facebook/opt-125m --num-prompts 100"

# Custom eval script in repo
https://github.com/THUDM/ChatGLM3  main  "python3 basic_demo/cli_demo.py --max-length 50 --prompt 'Hello world' --num-beams 1"
